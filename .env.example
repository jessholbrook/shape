# Shape — environment variables
#
# All optional. Without these set, Shape runs in local-only mode:
# artifacts publish to localStorage and /p/<handle>/<slug> only resolves in
# the browser that published them.

# Supabase project URL — found in Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — also in Project Settings → API.
# Safe to expose to the browser; row-level security gates writes.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
