# Shape — environment variables
#
# All optional. Without these set, Shape runs in local-only mode:
# artifacts publish to localStorage and /p/<handle>/<slug> only resolves in
# the browser that published them.

# Supabase project URL — found in Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — also in Project Settings → API.
# Safe to expose to the browser; row-level security gates writes.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Visitor demo (SPEC §12). When all three of the variables below are set, the
# "Try it" card on public artifact pages calls /api/demo, which proxies to
# Claude Haiku using DEMO_ANTHROPIC_KEY and rate-limits per IP via Supabase.
# Without them /api/demo returns 503 and the UI shows a "Demo not configured"
# placeholder.

# Pooled Anthropic API key used for visitor demos. NEVER ship this to the
# client — it's read server-side only.
DEMO_ANTHROPIC_KEY=

# Secret used to hash visitor IPs before storing them in demo_turns. Any random
# string of reasonable length works; rotating it invalidates existing counters.
DEMO_IP_SALT=

# Optional rate-limit overrides. Defaults: 5 demo turns per (IP, artifact) per
# day; 50 demo turns per IP per day across the site.
# DEMO_TURNS_PER_ARTIFACT_PER_DAY=5
# DEMO_TURNS_PER_IP_PER_DAY=50
